# Faydo Environment Variables
# Copy this file to .env and customize

# ===========================================
# Django Settings
# ===========================================
# Generate a secure secret key for production
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-this-to-a-secure-random-key

# Set to False in production
DEBUG=False

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=*

# ===========================================
# Database
# ===========================================
# Default: SQLite (no changes needed)
DATABASE_URL=sqlite:///db.sqlite3

# For PostgreSQL (optional):
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ===========================================
# Server Configuration
# ===========================================
# Port for HTTPS access
SERVER_PORT=9000

# ===========================================
# SMS Settings (Melipayamak)
# ===========================================
MELIPAYAMAK_USERNAME=your_username
MELIPAYAMAK_PASSWORD=your_password
MELIPAYAMAK_NUMBER=your_number
